# Zkopíruj jako `.env` a uprav hodnoty. Bez .env platí výchozí hodnoty
# z pubquiz/config.py (vhodné jen pro lokální testování!).

# Heslo do admin panelu
ADMIN_PASSWORD=kviz123

# Tajný klíč pro session — nastav libovolný dlouhý náhodný řetězec
SECRET_KEY=sem-dej-neco-nahodneho

# Veřejná adresa aplikace (použije se v QR kódu na projektoru)
# Lokálně: http://192.168.x.x:5000 (IP tvého počítače v místní síti)
# PythonAnywhere: https://uzivatel.pythonanywhere.com nebo https://uzivatel.eu.pythonanywhere.com
PUBLIC_URL=http://127.0.0.1:5000

# Interval pollingu klientů v milisekundách
POLL_INTERVAL_MS=2000

# Výchozí délka odpočtu po zavření odpovědí (sekundy)
DEFAULT_COUNTDOWN_S=5
